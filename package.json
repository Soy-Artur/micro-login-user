{
  "name": "micro-login-users-ruwark",
  "version": "1.0.0",
  "description": "Microservicio de autenticación y gestión de usuarios para el sistema Ruwark con MySQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:mysql": "node test-mysql-connection.js",
    "fix:passwords": "node regenerate-passwords.js",
    "migrate": "node src/migrations/run-migrations.js",
    "migrate:clientes": "node scripts/migrate-clientes-nombres.js",
    "cleanup:sessions": "node scripts/cleanup-sessions-now.js"
  },
  "keywords": [
    "microservice",
    "authentication",
    "users",
    "mysql",
    "ruwark"
  ],
  "author": "Ruwark Team",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.17.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
